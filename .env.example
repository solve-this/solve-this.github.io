# Google Sheets Translations — required for running `npm run fetch-translations`
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Service account credentials (from Google Cloud Console)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# The ID from the Google Spreadsheet URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=1m3TlNDa8J6bbXcbgqTOcH-UZdtxtqYJay3auj_xHA7g
